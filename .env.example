# ─────────────────────────────────────────────────────────────
# ApplyTrail — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub.
# ─────────────────────────────────────────────────────────────

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Your app URL (use http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials (from Google Cloud Console)
# See README for step-by-step setup instructions
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Database (SQLite — stored locally on your machine)
DATABASE_URL="file:./applytrail.db"

# ─────────────────────────────────────────────────────────────
# Optional: AI classification with Claude (your own key)
# ─────────────────────────────────────────────────────────────
# ApplyTrail works great without this — rule-based matching handles ~90% of emails.
# If you want smarter classification for ambiguous cases, add your own Claude API key.
# Get one free at: https://console.anthropic.com
# Your key stays on your machine and is never shared with anyone.
ANTHROPIC_API_KEY=
